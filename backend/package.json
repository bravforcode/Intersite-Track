{
  "name": "@intersite/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --watch server.ts",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "node --test --test-concurrency=1 --import tsx \"src/tests/**/*.spec.ts\"",
    "start:prod": "cross-env NODE_ENV=production node --import tsx server.ts",
    "health-check": "curl -sf http://localhost:3694/api/live || exit 1"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/pdfkit": "^0.17.5",
    "@vercel/blob": "^2.3.1",
    "axios": "^1.15.0",
    "axios-retry": "^4.5.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.18.0",
    "redis": "^4.6.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
