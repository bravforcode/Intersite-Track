uploads/

# Python
**/__pycache__/
.venv/

# Temp files
tmp/
*.tmp

# Word temp lock files
~$*.docx
~$*.xlsx

# Playwright
.playwright-cli/
test-results/
playwright-report/

# Generated performance reports
k6-report.html
k6-summary.json

# Backup docs generated during dev
*.backup-before-*.docx
