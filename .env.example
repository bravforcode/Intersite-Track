# ─── Firebase (Backend - Admin SDK) ──────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----\n"

# ─── Application ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3694

# ─── Frontend (Vite - Firebase JS SDK) ───────────────────────────
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=1:your-sender-id:web:your-app-id
VITE_APP_ENV=development
VITE_ENABLE_QUICK_LOGIN=false
VITE_QUICK_LOGIN_ADMIN_EMAIL=
VITE_QUICK_LOGIN_ADMIN_PASSWORD=
VITE_QUICK_LOGIN_STAFF_EMAIL=
VITE_QUICK_LOGIN_STAFF_PASSWORD=

# ─── Security ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (used in production for CORS)
ALLOWED_ORIGIN=http://localhost:3694

# ─── LINE Messaging ───────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_ADMIN_USER_ID=your-line-admin-user-id
# Optional legacy/manual bootstrap only:
# LINE_GROUP_ID is no longer required by the main flow because group_id
# is auto-saved to Firestore via /api/line/webhook when the bot joins a group.
# LINE_GROUP_ID=

# ─── Trello (for update-trello.ts script) ────────────────────────
TRELLO_API_KEY=your-trello-api-key
TRELLO_TOKEN=your-trello-token
TRELLO_BOARD_ID=TCoZ8cCj
