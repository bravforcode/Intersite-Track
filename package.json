{
  "name": "intersite-track",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:be\" \"npm run dev:fe\" --names be,fe --prefix-colors blue,green",
    "dev:fe": "npm run dev --workspace=frontend",
    "dev:be": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend",
    "build:be": "npm run build --workspace=backend",
    "lint": "npm run lint --workspaces --if-present",
    "test:root": "node --test --import tsx \"tests/unit/**/*.spec.js\"",
    "test": "npm run test:root && npm run test --workspaces --if-present",
    "clean": "rimraf dist frontend/dist backend/dist",
    "deploy:production": "bash scripts/deploy-production.sh",
    "test:e2e": "E2E_MOCK=1 npx playwright test",
    "test:cross-browser": "bash scripts/cross-browser-test.sh",
    "test:functional": "bash scripts/functional-test.sh",
    "test:performance:smoke": "bash scripts/performance-test-runner.sh smoke",
    "test:performance:load": "bash scripts/performance-test-runner.sh load",
    "test:performance:stress": "bash scripts/performance-test-runner.sh stress",
    "test:performance:spike": "bash scripts/performance-test-runner.sh spike",
    "test:performance:endurance": "bash scripts/performance-test-runner.sh endurance",
    "test:performance:all": "bash scripts/performance-test-runner.sh all",
    "verify:deployment": "bash scripts/deploy-verify.sh",
    "orchestrate:deployment": "bash scripts/complete-deployment-orchestrator.sh",
    "audit:security": "npm audit --production"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.25",
    "@types/express-serve-static-core": "^4.19.8",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1",
    "zod": "^4.3.6"
  }
}
